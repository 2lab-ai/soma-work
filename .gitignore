# Dependencies
node_modules/
.claude/
!.claude/skills/
!.claude/rules/

# Environment variables
.env
.env.dev
.env.local
.env.*.local

# Local config (not committed)
config.json
config.dev.json
.system.prompt
.system.prompt.dev
.setup-state
.setup-secrets.tmp
.new-deploy-state
.github-private-key.pem

# Build output
dist/
.deploy-bundle/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
nohup.out

# Plugin marketplace cache
plugins/

# User data
data/
data.dev/
# ...but the ui-ux skill ships its own bundled CSV `data/` assets (not user data).
!src/local/skills/ui-ux/data/
!src/local/skills/ui-ux/data/**
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript
*.tsbuildinfo

# somalib compiled output (generated by npm run build:somalib)
somalib/**/*.js
somalib/**/*.d.ts
somalib/**/*.js.map
somalib/**/*.d.ts.map

# process-shared compiled output. The package builds to dist/ (already
# ignored above), so any *.js/*.d.ts inside src/ is a stray in-place tsc
# artifact that must never be committed — when present it shadows the .ts
# source during test module resolution. (Root cause of the model-commands
# test quarantine, see vitest.config.ts.)
packages/process-shared/src/**/*.js
packages/process-shared/src/**/*.d.ts
packages/process-shared/src/**/*.js.map
packages/process-shared/src/**/*.d.ts.map

# Testing
coverage/
.nyc_output/

usercontent/
.system.prompt

# bd (beads)
.beads/daemon-error

# Git worktrees
.worktree/

# bv (beads viewer) local config and caches
.bv/

# Python bytecode (zkorean static checker ships .py only)
__pycache__/
*.pyc
*.pyo
