{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@soma/process-shared": ["node_modules/@soma/process-shared/dist/index"],
      "@soma/process-shared/*": ["node_modules/@soma/process-shared/dist/*"]
    }
  }
}
