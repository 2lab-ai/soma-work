{
  "name": "soma-work",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "npm run check && npm run build:somalib && tsc && cp -r src/prompt dist/ && cp -r src/persona dist/ && cp -r src/local dist/ && mkdir -p dist/metrics/usage-render && cp -r src/metrics/usage-render/assets dist/metrics/usage-render/",
    "build:somalib": "tsc -p somalib/tsconfig.json",
    "prod": "node dist/index.js",
    "check": "biome check src/ somalib/ scripts/",
    "lint": "tsc --noEmit && biome check src/ somalib/ scripts/",
    "format": "biome check --write src/ somalib/ scripts/",
    "format:check": "biome format src/ somalib/ scripts/",
    "test": "vitest run",
    "test:watch": "vitest",
    "mapping:list": "tsx scripts/update-slack-jira-mapping.ts list",
    "mapping:sync": "tsx scripts/update-slack-jira-mapping.ts sync",
    "mapping:add": "tsx scripts/update-slack-jira-mapping.ts add"
  },
  "workspaces": [
    "somalib"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/ioredis": "^4.28.10",
    "@types/node": "=24.0.4",
    "tsx": "=4.20.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.111",
    "@anthropic-ai/sdk": "^0.86.1",
    "@clickhouse/client": "^1.18.2",
    "@fastify/websocket": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@resvg/resvg-js": "^2.6.2",
    "@slack/bolt": "=4.7.0",
    "@slack/web-api": "^7.15.1",
    "@types/jsonwebtoken": "=9.0.10",
    "@types/node-fetch": "=2.6.12",
    "dotenv": "=16.6.0",
    "echarts": "^6.0.0",
    "fastify": "^5.7.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "=9.0.2",
    "markdown-to-slack-blocks": "^1.4.1",
    "mongodb": "^7.1.1",
    "mysql2": "^3.20.0",
    "node-fetch": "=3.3.2"
  }
}
