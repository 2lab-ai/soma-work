# Slack App Configuration (Required)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude Code Configuration (Optional - only needed if you don't use a Claude subscription)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# GitHub App Integration (Optional - Recommended for GitHub access)
# GITHUB_APP_ID=123456
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYour private key content here...\n-----END RSA PRIVATE KEY-----"
# GITHUB_INSTALLATION_ID=12345678

# GitHub Token Integration (Optional - Legacy fallback)
# GITHUB_TOKEN=ghp_your_personal_access_token

# Working Directory Configuration (Required)
# Base directory for user working directories
# Each user gets a fixed directory: {BASE_DIRECTORY}/{userId}/
BASE_DIRECTORY=/Users/username/Code/

# Jira Integration (Optional - for Jira status transitions in session list)
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your-jira-api-token

# Release Notification (Optional)
# Channel to post version/release notes on startup
# DEFAULT_UPDATE_CHANNEL=#ai

# Development Configuration (Optional)
# DEBUG=true

# Dispatch Configuration (Optional)
# Model used for routing messages to workflows (default: claude-haiku-4-5-20251001)
# DISPATCH_MODEL=claude-haiku-4-5-20251001

# Credential Manager Configuration (Optional)
# Enable local file credentials management (reads ~/.claude/.credentials.json)
# ENABLE_LOCAL_FILE_CREDENTIALS_JSON=1
# AUTOMATIC_RESTORE_CREDENTIAL=1
# CREDENTIAL_ALERT_CHANNEL=#backend-general

# Dashboard Web Server (Optional - for the web dashboard at /dashboard)
# CONVERSATION_VIEWER_TOKEN=your-secret-viewer-token
# CONVERSATION_VIEWER_URL=https://your-dashboard-url.example.com
# CONVERSATION_VIEWER_PORT=3000
# CONVERSATION_VIEWER_HOST=127.0.0.1

# Dashboard OAuth (Optional — enables Google/Microsoft sign-in on the dashboard)
# Requires CONVERSATION_VIEWER_URL to be set for OAuth callback URLs
#
# ── Google OAuth Setup Guide ──
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Select or create a project
# 3. Configure OAuth consent screen (APIs & Services > OAuth consent screen)
#    - User Type: Internal (org) or External
#    - Add scopes: openid, email, profile
#    - Add test users if External + unverified
# 4. Create credentials: + CREATE CREDENTIALS > OAuth client ID
#    - Application type: Web application
#    - Authorized redirect URIs: {CONVERSATION_VIEWER_URL}/auth/google/callback
#      e.g. http://localhost:3000/auth/google/callback
# 5. Copy Client ID and Client Secret below
#
# Generate JWT secret: openssl rand -hex 32
#
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# MICROSOFT_CLIENT_ID=your-microsoft-client-id
# MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
# DASHBOARD_JWT_SECRET=your-strong-random-secret-here
# DASHBOARD_JWT_EXPIRES_IN=604800

# Slack 5-block UI rollout (Issue #525, Phase 1+)
# Cumulative prefix: 0=legacy (default), 1=B1 stream via TurnSurface,
# 2=+B2 plan, 3=+B3 UIAskUserQuestion, 4=+B4 status, 5=+B5 completion.
# Values outside [0..5] fall back to 0 with a warning (fail-closed).
SOMA_UI_5BLOCK_PHASE=0
